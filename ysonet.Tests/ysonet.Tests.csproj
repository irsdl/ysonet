<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="14.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{7C2E1B90-6A2D-4F1E-9C3A-2E7B6D40AB01}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>ysonet.Tests</RootNamespace>
    <AssemblyName>ysonet.Tests</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>false</Deterministic>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <!-- Release exists only so the project compiles in a Release solution build.
       The test RUN (RunYsonetTests below) is Debug-only. -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="NDesk.Options, Version=0.2.1.0, Culture=neutral, processorArchitecture=MSIL">
      <HintPath>..\packages\NDesk.Options.0.2.1\lib\NDesk.Options.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Tests.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ysonet\ysonet.csproj">
      <Project>{6B40FDE7-14EA-4F57-8B7B-CC2EB4A25E6C}</Project>
      <Name>ysonet</Name>
    </ProjectReference>
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />

  <!--
    Run the interactive/core test suite automatically after a DEBUG build only.
    Release never runs it (the shipped binary is obfuscated and tests are a
    dev-time gate). The runner must execute from ysonet's own output folder so the
    bundled DLLs (Microsoft.PowerShell.Editor.dll, etc.) resolve, so we stage the
    test exe there and run it. A non-zero exit (any failed test) fails the build.

    Opt out for a one-off build with:  -p:RunYsonetTests=false
    Skipped automatically if that AnyCPU output is absent (e.g. a Debug|x64 build),
    so it never fails spuriously.
  -->
  <PropertyGroup>
    <RunYsonetTests Condition="'$(RunYsonetTests)' == ''">true</RunYsonetTests>
    <YsonetOutDir>$(MSBuildProjectDirectory)\..\ysonet\bin\Debug</YsonetOutDir>
  </PropertyGroup>
  <Target Name="RunYsonetTests" AfterTargets="Build"
          Condition="'$(Configuration)' == 'Debug' and '$(RunYsonetTests)' != 'false' and Exists('$(YsonetOutDir)\ysonet.exe')">
    <Message Importance="high" Text="RunYsonetTests: running interactive/core tests from $(YsonetOutDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(YsonetOutDir)" OverwriteReadOnlyFiles="true" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFolder="$(YsonetOutDir)"
          OverwriteReadOnlyFiles="true" Condition="Exists('$(TargetDir)$(TargetName).pdb')" />
    <Exec Command="&quot;$(YsonetOutDir)\ysonet.Tests.exe&quot;" WorkingDirectory="$(YsonetOutDir)" />
  </Target>
</Project>
